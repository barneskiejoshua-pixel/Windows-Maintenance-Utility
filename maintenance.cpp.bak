#include <iostream>
#include <cstdlib>
#include <windows.h>
#include <string>
#include <shellapi.h>

using namespace std;

// Compilation instructions for portable executable:
// For MinGW/GCC:
// g++ -static -static-libgcc -static-libstdc++ -O2 -s -fno-stack-protector -o system_maintenance.exe system_maintenance.cpp
//
// For Visual Studio (Release mode):
// cl /MT /O2 system_maintenance.cpp /Fe:system_maintenance.exe

// Helper function to check if running as administrator
bool isRunningAsAdmin() {
    BOOL isAdmin = FALSE;
    PSID adminGroup = NULL;
    
    SID_IDENTIFIER_AUTHORITY ntAuthority = SECURITY_NT_AUTHORITY;
    
    if (AllocateAndInitializeSid(&ntAuthority, 2, SECURITY_BUILTIN_DOMAIN_RID,
                                DOMAIN_ALIAS_RID_ADMINS, 0, 0, 0, 0, 0, 0, &adminGroup)) {
        CheckTokenMembership(NULL, adminGroup, &isAdmin);
        FreeSid(adminGroup);
    }
    
    return isAdmin == TRUE;
}

// Function to restart the program with administrator privileges
bool restartAsAdmin() {
    char szPath[MAX_PATH];
    if (GetModuleFileNameA(NULL, szPath, ARRAYSIZE(szPath))) {
        // Launch itself with administrator privileges
        SHELLEXECUTEINFOA sei = { sizeof(sei) };
        sei.lpVerb = "runas";          // Request elevation
        sei.lpFile = szPath;           // Path to current executable
        sei.hwnd = NULL;
        sei.nShow = SW_NORMAL;
        
        if (ShellExecuteExA(&sei)) {
            return true; // Successfully launched elevated version
        } else {
            DWORD error = GetLastError();
            if (error == ERROR_CANCELLED) {
                cout << "User cancelled the elevation request.\n";
            } else {
                cout << "Failed to restart as administrator. Error: " << error << "\n";
            }
            return false;
        }
    }
    return false;
}

// Run Disk Cleanup
int runCleanMgr() {
    cout << "Starting automated Disk Cleanup (cleanmgr /sagerun:1)...\n";
    cout << "Running with predefined cleanup settings.\n\n";
    
    int result = system("cleanmgr /sagerun:1");
    
    if (result == 0) {
        cout << "Automated Disk Cleanup completed successfully.\n";
        return 0;
    } else {
        cout << "Failed to run automated Disk Cleanup. Error code: " << result << "\n";
        cout << "Note: You may need to run 'cleanmgr /sageset:1' first to configure settings.\n";
        return -1;
    }
}

// Run System File Checker
int runSFC() {
    cout << "Starting System File Checker (sfc /scannow)...\n";
    cout << "This may take several minutes to complete.\n";
    cout << "Please wait...\n\n";
    
    int result = system("sfc /scannow");
    
    if (result == 0) {
        cout << "System File Checker completed successfully.\n";
        return 0;
    } else {
        cout << "System File Checker failed. Error code: " << result << "\n";
        return -1;
    }
}

// Clear Windows Update Cache
int clearUpdateCache() {
    cout << "Clearing Windows Update download cache...\n";
    cout << "This will delete temporary update files to free space.\n\n";
    
    int result = system("del /q /f /s C:\\Windows\\SoftwareDistribution\\Download\\*");
    
    if (result == 0) {
        cout << "Windows Update cache cleared successfully.\n";
        return 0;
    } else {
        cout << "Failed to clear Windows Update cache. Error code: " << result << "\n";
        return -1;
    }
}

// Flush DNS Cache
int flushDNS() {
    cout << "Flushing DNS cache...\n";
    cout << "This will clear DNS resolver cache for fresh lookups.\n\n";
    
    int result = system("ipconfig /flushdns");
    
    if (result == 0) {
        cout << "DNS cache flushed successfully.\n";
        return 0;
    } else {
        cout << "Failed to flush DNS cache. Error code: " << result << "\n";
        return -1;
    }
}

// Clear Prefetch Cache
int clearPrefetch() {
    cout << "Clearing Windows Prefetch cache...\n";
    cout << "This will delete application prefetch data to improve performance.\n\n";
    
    int result = system("del /q /f /s C:\\Windows\\Prefetch\\*");
    
    if (result == 0) {
        cout << "Prefetch cache cleared successfully.\n";
        return 0;
    } else {
        cout << "Failed to clear Prefetch cache. Error code: " << result << "\n";
        return -1;
    }
}

// DISM Component Store Cleanup
int dismCleanup() {
    cout << "Starting DISM Component Store cleanup...\n";
    cout << "This will clean up superseded Windows components and may take several minutes.\n\n";
    
    int result = system("dism /Online /Cleanup-Image /StartComponentCleanup");
    
    if (result == 0) {
        cout << "DISM Component Store cleanup completed successfully.\n";
        return 0;
    } else {
        cout << "DISM Component Store cleanup failed. Error code: " << result << "\n";
        return -1;
    }
}

// Clear Chrome Cache
int clearChromeCache() {
    cout << "Clearing Google Chrome cache...\n";
    cout << "This will delete Chrome's temporary internet files and cached data.\n\n";
    
    int result = system("del /q /s \"%LocalAppData%\\Google\\Chrome\\User Data\\Default\\Cache\\*\"");
    
    if (result == 0) {
        cout << "Chrome cache cleared successfully.\n";
        return 0;
    } else {
        cout << "Failed to clear Chrome cache (Chrome may not be installed or cache already empty).\n";
        return -1;
    }
}

// Update all applications via Winget
int wingetUpgradeAll() {
    cout << "Updating all applications via Windows Package Manager (winget)...\n";
    cout << "This will check for and install updates for all winget-managed applications.\n";
    cout << "This may take several minutes depending on available updates.\n\n";
    
    int result = system("winget upgrade --all");
    
    if (result == 0) {
        cout << "Winget application updates completed successfully.\n";
        return 0;
    } else {
        cout << "Winget upgrade failed or no updates available. Error code: " << result << "\n";
        cout << "Note: Winget requires Windows 10 version 1709 or later.\n";
        return -1;
    }
}

int main() {
    cout << "=== Windows System Maintenance Utility v1.0 ===\n";
    cout << "Safe system utility for disk cleanup and file checking\n";
    cout << "===============================================\n\n";
    
    // Check if running as administrator
    if (!isRunningAsAdmin()) {
        cout << "This program requires administrator privileges.\n";
        cout << "Attempting to restart with administrator rights...\n\n";
        
        if (restartAsAdmin()) {
            cout << "Restarting with administrator privileges...\n";
            return 0; // Exit this instance, elevated version will run
        } else {
            cout << "Failed to obtain administrator privileges.\n";
            cout << "Please manually run this program as administrator.\n\n";
            cout << "Press Enter to exit...";
            cin.get();
            return 1;
        }
    }
    
    cout << "Running with administrator privileges - Good!\n\n";
    
    cout << "Starting automated maintenance tasks...\n\n";
    
    // Run all seven tasks automatically
    int result = 0;
    
    // First run Disk Cleanup
    result = runCleanMgr();
    
    // If successful, run System File Checker
    if (result == 0) {
        cout << "\n" << string(50, '=') << "\n";
        cout << "Disk Cleanup completed. Starting System File Checker...\n";
        cout << string(50, '=') << "\n\n";
        result = runSFC();
        
        // If SFC successful, clear Windows Update cache
        if (result == 0) {
            cout << "\n" << string(50, '=') << "\n";
            cout << "System File Checker completed. Clearing Windows Update cache...\n";
            cout << string(50, '=') << "\n\n";
            result = clearUpdateCache();
            
            // If Update cache clear successful, flush DNS
            if (result == 0) {
                cout << "\n" << string(50, '=') << "\n";
                cout << "Update cache cleared. Flushing DNS cache...\n";
                cout << string(50, '=') << "\n\n";
                result = flushDNS();
                
                // If DNS flush successful, clear Prefetch
                if (result == 0) {
                    cout << "\n" << string(50, '=') << "\n";
                    cout << "DNS cache flushed. Clearing Prefetch cache...\n";
                    cout << string(50, '=') << "\n\n";
                    result = clearPrefetch();
                    
                    // If Prefetch clear successful, run DISM cleanup
                    if (result == 0) {
                        cout << "\n" << string(50, '=') << "\n";
                        cout << "Prefetch cleared. Starting DISM Component Store cleanup...\n";
                        cout << string(50, '=') << "\n\n";
                        result = dismCleanup();
                        
                        // If DISM cleanup successful, clear Chrome cache
                        if (result == 0) {
                            cout << "\n" << string(50, '=') << "\n";
                            cout << "DISM cleanup completed. Clearing Chrome cache...\n";
                            cout << string(50, '=') << "\n\n";
                            result = clearChromeCache();
                        } else {
                            cout << "\nDISM cleanup failed. Skipping Chrome cache cleanup.\n";
                        }
                    } else {
                        cout << "\nPrefetch cleanup failed. Skipping remaining tasks.\n";
                    }
                } else {
                    cout << "\nDNS flush failed. Skipping remaining tasks.\n";
                }
            } else {
                cout << "\nWindows Update cache cleanup failed. Skipping remaining tasks.\n";
            }
        } else {
            cout << "\nSystem File Checker failed. Skipping remaining tasks.\n";
        }
    } else {
        cout << "\nDisk Cleanup failed. Skipping remaining tasks.\n";
    }
    
    cout << "\n=== Maintenance Complete ===\n";
    if (result == 0) {
        cout << "All selected tasks completed successfully.\n";
    } else {
        cout << "Some tasks may have encountered issues. Check output above.\n";
    }
    
    cout << "\nPress Enter to exit...";
    cin.ignore();
    cin.get();
    
    return result;
}